common --enable_bzlmod
common --lockfile_mode=update

# Preserve Bazel 6 glob semantics: some `library()` macro call-sites in this
# repo rely on empty globs (e.g. packages that only have subpackages).
common --noincompatible_disallow_empty_glob

build --java_language_version=17
build --java_runtime_version=remotejdk_17
build --tool_java_language_version=17
build --tool_java_runtime_version=remotejdk_17

test --test_output=errors

# CI profile: enables a disk cache for compiled outputs across runs.
build:ci --disk_cache=/tmp/bazel-disk-cache
